{% doc %}
  @prompt
    Create a Shopify custom section named "Features Slider" with the following requirements:
    
    Layout:
    
    Desktop: Show 3 feature blocks in a grid (3 columns).
    
    Mobile: Show the features as a horizontal swipeable slider (carousel).
    
    Each feature should be centered with icon, heading, and description.
    
    Add pagination dots below the slider on mobile only.
    
    The active dot should turn black, inactive dots should be gray.
    
    The slider should snap smoothly between items.
    
    Features to include:
    
    Icon, Heading: "30-Day Return Guarantee"
    Description: "Not satisfied? Get your full purchase amount back!"
    
    Icon, Heading: "Free Shipping"
    Description: "Take advantage of free shipping on every order now!"
    
    Icon, Heading: "Secure Payment"
    Description: "Shop with peace of mind using our secure payment options."
    
    Design requirements:
    
    Clean, minimal, modern design
    
    Icons above text, centered
    
    Heading font-weight semi-bold
    
    Description smaller and gray
    
    Proper spacing between elements
    
    Fully responsive
    
    Max width: 5xl and centered
    
    Technical requirements:
    
    Must be compatible with Shopify themes
    
    Use TailwindCSS styling (or equivalent CSS)
    
    No external dependencies except Tailwind CDN if needed
    
    Include smooth scrolling and clickable pagination dots
    
    Prevent scrollbar from showing on mobile
    
    Section must be reusable and customizable from Shopify Theme Editor
    
    Section settings:
    
    Allow editing:
    
    Heading text
    
    Description text
    
    Icon (SVG or image)
    
    Allow adding/removing feature blocks, you have to keep the card center at mobile
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-features-slider-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .ai-features-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .ai-feature-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  .ai-feature-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-feature-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-feature-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-feature-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: 600;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-feature-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-features-slider-container-{{ ai_gen_id }} {
    display: none;
    position: relative;
  }

  .ai-features-slider-wrapper-{{ ai_gen_id }} {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .ai-features-slider-wrapper-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-features-slider-track-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
  }

  .ai-feature-slide-{{ ai_gen_id }} {
    flex: 0 0 100%;
    scroll-snap-align: center;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .ai-pagination-dots-{{ ai_gen_id }} {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 24px;
  }

  .ai-pagination-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_inactive_color }};
    border: none;
    padding: 0;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-pagination-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 768px) {
    .ai-features-grid-{{ ai_gen_id }} {
      display: none;
    }

    .ai-features-slider-container-{{ ai_gen_id }} {
      display: block;
    }
  }
{% endstyle %}

<features-slider-{{ ai_gen_id }} class="ai-features-slider-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-features-grid-{{ ai_gen_id }}">
    {% if block.settings.feature_1_heading != blank %}
      <div class="ai-feature-item-{{ ai_gen_id }}">
        <div class="ai-feature-icon-{{ ai_gen_id }}">
          {% if block.settings.feature_1_icon != blank %}
            <img src="{{ block.settings.feature_1_icon | image_url: width: 200 }}" alt="{{ block.settings.feature_1_heading | escape }}" loading="lazy">
          {% else %}
            {{ block.settings.feature_1_icon_svg }}
          {% endif %}
        </div>
        <h3 class="ai-feature-heading-{{ ai_gen_id }}">{{ block.settings.feature_1_heading }}</h3>
        <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_1_description }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_2_heading != blank %}
      <div class="ai-feature-item-{{ ai_gen_id }}">
        <div class="ai-feature-icon-{{ ai_gen_id }}">
          {% if block.settings.feature_2_icon != blank %}
            <img src="{{ block.settings.feature_2_icon | image_url: width: 200 }}" alt="{{ block.settings.feature_2_heading | escape }}" loading="lazy">
          {% else %}
            {{ block.settings.feature_2_icon_svg }}
          {% endif %}
        </div>
        <h3 class="ai-feature-heading-{{ ai_gen_id }}">{{ block.settings.feature_2_heading }}</h3>
        <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_2_description }}</p>
      </div>
    {% endif %}

    {% if block.settings.feature_3_heading != blank %}
      <div class="ai-feature-item-{{ ai_gen_id }}">
        <div class="ai-feature-icon-{{ ai_gen_id }}">
          {% if block.settings.feature_3_icon != blank %}
            <img src="{{ block.settings.feature_3_icon | image_url: width: 200 }}" alt="{{ block.settings.feature_3_heading | escape }}" loading="lazy">
          {% else %}
            {{ block.settings.feature_3_icon_svg }}
          {% endif %}
        </div>
        <h3 class="ai-feature-heading-{{ ai_gen_id }}">{{ block.settings.feature_3_heading }}</h3>
        <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_3_description }}</p>
      </div>
    {% endif %}
  </div>

  <div class="ai-features-slider-container-{{ ai_gen_id }}">
    <div class="ai-features-slider-wrapper-{{ ai_gen_id }}">
      <div class="ai-features-slider-track-{{ ai_gen_id }}">
        {% if block.settings.feature_1_heading != blank %}
          <div class="ai-feature-slide-{{ ai_gen_id }}" data-slide-index="0">
            <div class="ai-feature-item-{{ ai_gen_id }}">
              <div class="ai-feature-icon-{{ ai_gen_id }}">
                {% if block.settings.feature_1_icon != blank %}
                  <img src="{{ block.settings.feature_1_icon | image_url: width: 200 }}" alt="{{ block.settings.feature_1_heading | escape }}" loading="lazy">
                {% else %}
                  {{ block.settings.feature_1_icon_svg }}
                {% endif %}
              </div>
              <h3 class="ai-feature-heading-{{ ai_gen_id }}">{{ block.settings.feature_1_heading }}</h3>
              <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_1_description }}</p>
            </div>
          </div>
        {% endif %}

        {% if block.settings.feature_2_heading != blank %}
          <div class="ai-feature-slide-{{ ai_gen_id }}" data-slide-index="1">
            <div class="ai-feature-item-{{ ai_gen_id }}">
              <div class="ai-feature-icon-{{ ai_gen_id }}">
                {% if block.settings.feature_2_icon != blank %}
                  <img src="{{ block.settings.feature_2_icon | image_url: width: 200 }}" alt="{{ block.settings.feature_2_heading | escape }}" loading="lazy">
                {% else %}
                  {{ block.settings.feature_2_icon_svg }}
                {% endif %}
              </div>
              <h3 class="ai-feature-heading-{{ ai_gen_id }}">{{ block.settings.feature_2_heading }}</h3>
              <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_2_description }}</p>
            </div>
          </div>
        {% endif %}

        {% if block.settings.feature_3_heading != blank %}
          <div class="ai-feature-slide-{{ ai_gen_id }}" data-slide-index="2">
            <div class="ai-feature-item-{{ ai_gen_id }}">
              <div class="ai-feature-icon-{{ ai_gen_id }}">
                {% if block.settings.feature_3_icon != blank %}
                  <img src="{{ block.settings.feature_3_icon | image_url: width: 200 }}" alt="{{ block.settings.feature_3_heading | escape }}" loading="lazy">
                {% else %}
                  {{ block.settings.feature_3_icon_svg }}
                {% endif %}
              </div>
              <h3 class="ai-feature-heading-{{ ai_gen_id }}">{{ block.settings.feature_3_heading }}</h3>
              <p class="ai-feature-description-{{ ai_gen_id }}">{{ block.settings.feature_3_description }}</p>
            </div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-pagination-dots-{{ ai_gen_id }}">
      {% if block.settings.feature_1_heading != blank %}
        <button class="ai-pagination-dot-{{ ai_gen_id }} active" data-dot-index="0" aria-label="Go to slide 1"></button>
      {% endif %}
      {% if block.settings.feature_2_heading != blank %}
        <button class="ai-pagination-dot-{{ ai_gen_id }}" data-dot-index="1" aria-label="Go to slide 2"></button>
      {% endif %}
      {% if block.settings.feature_3_heading != blank %}
        <button class="ai-pagination-dot-{{ ai_gen_id }}" data-dot-index="2" aria-label="Go to slide 3"></button>
      {% endif %}
    </div>
  </div>
</features-slider-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturesSlider{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.slider = null;
        this.dots = [];
        this.currentIndex = 0;
      }

      connectedCallback() {
        this.slider = this.querySelector('.ai-features-slider-wrapper-{{ ai_gen_id }}');
        this.dots = Array.from(this.querySelectorAll('.ai-pagination-dot-{{ ai_gen_id }}'));
        
        if (!this.slider) return;

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.slider.addEventListener('scroll', this.handleScroll.bind(this));

        this.dots.forEach((dot) => {
          dot.addEventListener('click', (e) => {
            const index = parseInt(e.target.getAttribute('data-dot-index'));
            this.scrollToSlide(index);
          });
        });
      }

      handleScroll() {
        if (this.scrollTimeout) {
          clearTimeout(this.scrollTimeout);
        }

        this.scrollTimeout = setTimeout(() => {
          this.updateActiveDot();
        }, 100);
      }

      updateActiveDot() {
        const slides = Array.from(this.querySelectorAll('.ai-feature-slide-{{ ai_gen_id }}'));
        const sliderRect = this.slider.getBoundingClientRect();
        const sliderCenter = sliderRect.left + sliderRect.width / 2;

        let closestIndex = 0;
        let closestDistance = Infinity;

        slides.forEach((slide, index) => {
          const slideRect = slide.getBoundingClientRect();
          const slideCenter = slideRect.left + slideRect.width / 2;
          const distance = Math.abs(slideCenter - sliderCenter);

          if (distance < closestDistance) {
            closestDistance = distance;
            closestIndex = index;
          }
        });

        this.currentIndex = closestIndex;

        this.dots.forEach((dot, index) => {
          if (index === closestIndex) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      scrollToSlide(index) {
        const slides = Array.from(this.querySelectorAll('.ai-feature-slide-{{ ai_gen_id }}'));
        if (slides[index]) {
          const slide = slides[index];
          const sliderRect = this.slider.getBoundingClientRect();
          const slideRect = slide.getBoundingClientRect();
          const scrollLeft = this.slider.scrollLeft + slideRect.left - sliderRect.left;

          this.slider.scrollTo({
            left: scrollLeft,
            behavior: 'smooth'
          });
        }
      }
    }

    customElements.define('features-slider-{{ ai_gen_id }}', FeaturesSlider{{ ai_gen_id }});
  })();
</script>

